# Copy to `.env.test` (gitignored) for Playwright E2E runs.
# Values must match backend seed credentials in `backend/.env`.

SEED_DISPATCHER_EMAIL=dispatcher@example.com
SEED_DISPATCHER_PASSWORD=your-local-dispatcher-password
SEED_DRIVER_PINS=0000,0001,0002,0003

# Optional E2E overrides (default to SEED_* above)
# E2E_DISPATCHER_EMAIL=
# E2E_DISPATCHER_PASSWORD=
# E2E_DRIVER1_PIN=
# E2E_DRIVER2_PIN=
