{
  "name": "iaw-saas",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev:backend": "npm run dev --prefix backend",
    "dev:frontend": "npm run dev --prefix frontend",
    "dev": "node scripts/dev.mjs",
    "build:backend": "npm run build --prefix backend",
    "build:frontend": "npm run build --prefix frontend",
    "build": "npm run build:backend && npm run build:frontend",
    "test:backend": "npm run test --prefix backend",
    "test:e2e": "playwright test",
    "test": "node scripts/test-all.mjs",
    "seed": "npx ts-node backend/src/seed.ts",
    "reseed:archive": "npx ts-node backend/src/runArchiveReseed.ts",
  "setup:fly": "bash scripts/setup-fly.sh",
    "postinstall": "npm install --prefix backend && npm install --prefix frontend"
  },
  "devDependencies": {
    "@playwright/test": "^1.45.0",
    "@types/node": "^20.0.0",
    "concurrently": "^9.0.0",
    "typescript": "^5.0.0"
  }
}
