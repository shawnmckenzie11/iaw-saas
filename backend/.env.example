DATABASE_URL="postgresql://postgres:postgres@localhost:5432/iaw_courier?schema=public"
PORT=3002
JWT_SECRET="change-me-in-production-use-openssl-rand-hex-32"

# Seed credentials (required for `npm run seed` — never commit real values)
SEED_DISPATCHER_EMAIL=dispatcher@example.com
SEED_DISPATCHER_PASSWORD=your-local-dispatcher-password
# Optional additional dispatchers (index 2–5)
# SEED_DISPATCHER_2_EMAIL=another-dispatcher@example.com
# SEED_DISPATCHER_2_PASSWORD=your-password
# SEED_DISPATCHER_2_FIRST_NAME=First
# SEED_DISPATCHER_2_LAST_NAME=Last
SEED_DRIVER_PINS=0000,0001,0002,0003
# Or per-driver: SEED_DRIVER_01_PIN=0000 … SEED_DRIVER_04_PIN=0003

# Optional archive reseed (destructive — wipes waybills when clearExisting=true)
# SEED_ARCHIVE_RESEED=true
# ARCHIVE_CSV_PATH=/absolute/path/to/archive.csv

# Production (Fly.io) — set via `fly secrets set`
# NODE_ENV=production
# SERVE_FRONTEND=true
# FRONTEND_DIST=/app/frontend/dist
# PORT=8080
# PUBLIC_APP_URL=https://iaw.mckenzian.com

# Google Sheets intake (temporary bridge — see DEPLOY.md)
# INTAKE_GOOGLE_SHEETS_ENABLED=true
# GOOGLE_SHEETS_SPREADSHEET_ID=your-spreadsheet-id
# GOOGLE_SERVICE_ACCOUNT_JSON='{"type":"service_account",...}'
# INTAKE_GOOGLE_SHEETS_INTERVAL_MS=60000
