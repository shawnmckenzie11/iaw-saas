{
  "name": "iaw-saas-backend",
  "version": "1.1.0",
  "description": "IAW Courier SaaS Backend",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "rimraf dist && tsc",
    "start": "node dist/server.js",
    "seed": "ts-node src/seed.ts",
    "seed:prod": "node dist/seed.js",
    "reseed:archive": "ts-node src/runArchiveReseed.ts",
    "reseed:archive:prod": "node dist/runArchiveReseed.js",
    "restore:deliveries": "ts-node src/restoreDeliveryData.ts",
    "restore:deliveries:prod": "node dist/restoreDeliveryData.js",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "test": "jest --runInBand --detectOpenHandles"
  },
  "dependencies": {
    "@prisma/client": "^5.16.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "decimal.js": "^10.4.3",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "googleapis": "^144.0.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.14.9",
    "@types/supertest": "^6.0.2",
    "jest": "^29.7.0",
    "prisma": "^5.16.0",
    "rimraf": "^5.0.7",
    "supertest": "^7.0.0",
    "ts-jest": "^29.1.5",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.2"
  }
}
